   1          /* SchM实现：进入临界区时保存EA，退出时恢复EA。 */
   2          
   3          #include "SchM.h"
   4          
   5          /* 保存进入临界区前的EA，避免退出时误开中断。 */
   6          static boolean SchM_UartRxDataSavedEa;
   7          
   8          /* 进入UART接收数据临界区：暂时关总中断，避免读写接收缓存时被打断。 */
   9          void SchM_Enter_Uart_RxData(void)
  10          {
  11   1          SchM_UartRxDataSavedEa = EA;   /* 先存当前中断状态 */
  12   1          EA = 0;                        /* 再关总中断 */
  13   1      }
  14          
  15          /* 退出UART接收数据临界区：恢复进入前的总中断状态。 */
  16          void SchM_Exit_Uart_RxData(void)
  17          {
  18   1          EA = SchM_UartRxDataSavedEa;   /* 恢复之前存的中断状态 */
  19   1      }


