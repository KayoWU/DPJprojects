   1          /* Delay实现：用嵌套空循环粗略消耗时间。 */
   2          
   3          #include "Delay.h"
   4          
   5          /* 阻塞延时：靠空循环消耗时间，简单但CPU会一直等在这里。 */
   6          void Delay_WaitMs(uint16 ms)
   7          {
   8   1          uint i, j;
   9   1          for(i = ms; i > 0; i--)          /* 外层：ms 次 */
