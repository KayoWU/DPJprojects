  18          static void Swc_Storage_StartSave(void)
  19          {
  20   1          uint8 writeData[SWC_STORAGE_DATA_LENGTH];
  21   1          uint8 adcRaw;
  22   1          uint16 adcMv;
  23   1      
  24   1          if(Rte_At24c02IsBusy() == TRUE)
  25   1          {
  26   2              /* EEPROM状态机仍在跑，本次命令只提示忙，不打断当前任务。 */
  27   2              Rte_DisplayRequestStatusLine("AT24 BUSY");
  28   2              return;
  29   2          }
  30   1      
  31   1          /* EEPROM保存3字节：ADC原始值 + 毫伏高字节 + 毫伏低字节。 */
  32   1          adcRaw = Rte_ReadAdcRaw();
  33   1          adcMv = Rte_ReadAdcMv();
  34   1          writeData[0] = adcRaw;
  35   1          writeData[1] = (uint8)(adcMv >> 8);
  36   1          writeData[2] = (uint8)adcMv;
  37   1          if(Rte_At24c02AsyncWrite(SWC_STORAGE_AT24_ADDRESS, writeData, SWC_STORAGE_DATA_LENGTH) == E_OK)
  38   1          {
  39   2              Swc_Storage_Job = SWC_STORAGE_JOB_SAVE;
  40   2              Rte_DisplayRequestStatusLine("SAVING..."); /* 先显示进行中，完成后再显示SAVE OK。 */
  41   2          }
  42   1      }
  43          
  44          static void Swc_Storage_StartRead(void)
  45          {
  46   1          if(Rte_At24c02IsBusy() == TRUE)
  47   1          {
  48   2              /* 读写共用同一个AT24C02状态机，忙时不发起新任务。 */
  49   2              Rte_DisplayRequestStatusLine("AT24 BUSY");
  50   2              return;
  51   2          }
C51 COMPILER V9.54   SWC_STORAGE                                                           06/02/2026 03:02:38 PAGE 2   

  52   1      
  53   1          /* 只发起异步读，读完后的处理在CheckDone里完成。 */
  54   1          if(Rte_At24c02AsyncRead(SWC_STORAGE_AT24_ADDRESS, SWC_STORAGE_DATA_LENGTH) == E_OK)
