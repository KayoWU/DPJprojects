  59   1      }
  60          
  61          static void Swc_Storage_CheckDone(void)
  62          {
  63   1          uint8 adcRaw;
  64   1          uint16 adcMv;
  65   1      
  66   1          if((Swc_Storage_Job != SWC_STORAGE_JOB_NONE) && (Rte_At24c02IsJobDone() == TRUE))
