  78   3                  Rte_DisplayRequestReadLine(adcRaw, adcMv);   /* LCD第二行显示读回值 */
  79   3                  Rte_RequestSerialReadMessage(adcRaw, adcMv); /* 同步请求串口回传 */
  80   3              }
  81   2              Swc_Storage_Job = SWC_STORAGE_JOB_NONE;
  82   2          }
  83   1      }
