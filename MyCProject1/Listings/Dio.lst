   1          /* Dio实现：检查逻辑ID后直接写8051端口寄存器。 */
   2          
   3          #include "Dio.h"
   4          #include "Det.h"
   5          
   6          /* 写整个端口8位：当前只支持P1，非法端口号会报到Det。 */
   7          void Dio_WritePort(uint8 portId, uint8 portLevel)
   8          {
   9   1          if(portId == DIO_PORT_P1)
  10   1          {
  11   2              P1 = portLevel;  /* 一次写8位：P1.0~P1.7 */
  12   2          }
  13   1          else
  14   1          {
  15   2              (void)Det_ReportError(DIO_MODULE_ID, DIO_INSTANCE_ID,
  16   2                                    DIO_WRITE_PORT_API_ID, DIO_E_PARAM_INVALID_PORT_ID);
  17   2          }
  18   1      }
  19          
  20          /* 写单个引脚1位：当前支持P2.3和P2.5，非法通道号会报到Det。 */
  21          void Dio_WriteChannel(uint8 channelId, uint8 channelLevel)
  22          {
  23   1          if(channelId == DIO_CHANNEL_P23)
  24   1          {
  25   2              P23 = channelLevel;  /* 写单个位：P2.3 */
  26   2          }
  27   1          else if(channelId == DIO_CHANNEL_P25)
  28   1          {
  29   2              P25 = channelLevel;  /* 写单个位：P2.5 */
  30   2          }
  31   1          else
  32   1          {
  33   2              (void)Det_ReportError(DIO_MODULE_ID, DIO_INSTANCE_ID,
  34   2                                    DIO_WRITE_CHANNEL_API_ID, DIO_E_PARAM_INVALID_CHANNEL_ID);
  35   2          }
  36   1      }


