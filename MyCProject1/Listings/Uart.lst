   1          /* UART底层驱动：配置8051串口和Timer1波特率，中断里收发字节。 */
   2          
   3          #include "Uart.h"
   4          #include "Uart_Cfg.h"
   5          #include "SchM.h"
   6          
   7          /* 接收缓存：中断写入，主循环读取，读写时用SchM保护。 */
   8          static volatile uint8 Uart_RxData;
   9          
  10          /* TRUE表示上一个字节还没发完，避免连续写SBUF覆盖数据。 */
  11          static volatile boolean Uart_TxBusy = FALSE;
  12          
  13          /* 串口初始化：模式1接收，Timer1自动重装产生9600波特率，开启串口中断。 */
  14          void Uart_Init(void)
  15          {
  16   1          SCON = 0x50;                                   /* 模式1, REN=1(允许接收) */
  17   1          PCON = PCON & 0x7f;                            /* SMOD=0, 波特率不加倍 */
  18   1          ES   = 1;                                      /* 开串口中断 */
  19   1          TMOD = 0x20;                                   /* T1: 8位自动重装 */
  20   1          TH1  = TL1 = 256 - (UART_FOSC / 12 / 32 / UART_BAUD); /* 波特率 = 晶振/12/32/(256-TH1) */
  21   1          Uart_TxBusy = FALSE;
  22   1          TR1  = 1;                                      /* 启动定时器1 */
  23   1          EA   = 1;                                      /* 开总中断 */
  24   1      }
  25          
  26          /* 读取收到的字节：临界区内取值，避免和串口中断同时访问。 */
  27          uint8 Uart_GetReceivedData(void)
  28          {
  29   1          uint8 rxData;
  30   1      
  31   1          SchM_Enter_Uart_RxData();  /* 关中断 */
  32   1          rxData = Uart_RxData;      /* 安全读取 */
  33   1          SchM_Exit_Uart_RxData();   /* 恢复中断 */
  34   1      
  35   1          return rxData;
  36   1      }
  37          
  38          /* 清除接收缓存：上层消费完命令后调用。 */
  39          void Uart_ClearReceivedData(void)
  40          {
  41   1          SchM_Enter_Uart_RxData();
  42   1          Uart_RxData = 0u;
  43   1          SchM_Exit_Uart_RxData();
  44   1      }
  45          
  46          /* 发送一个字节：SBUF只能在空闲时写，发送完成由TI中断释放忙标志。 */
  47          void Uart_SendByte(uint8 txData)
  48          {
  49   1          if(Uart_TxBusy == FALSE)
  50   1          {
  51   2              Uart_TxBusy = TRUE;
C51 COMPILER V9.54   UART                                                                  06/02/2026 03:02:39 PAGE 2   

  52   2              SBUF = txData;  /* 写发送缓冲 → 硬件自动开始发送 */
