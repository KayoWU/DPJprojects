   1          /**
   2           * @file    App_Command.c
   3           * @brief   Command protocol implementation
   4           *
   5           * Maps the 4 UART commands to board I/O actions through RTE.
   6           * The command code doubles as the default display value —
   7           * command 4 overrides this to clear (0).
   8           */
   9          
  10          #include "App_Command.h"
  11          #include "Rte.h"
  12          
  13          /* 命令处理：把串口收到的1/2/3/4转成对应板级动作和显示值。 */
  14          uint8 App_CommandProcess(uint8 command)
  15          {
  16   1          uint8 displayValue;
  17   1      
  18   1          displayValue = command;  /* 默认显示值 = 命令本身(1→"1", 2→"2", 3→"3") */
  19   1      
  20   1          if(command == APP_COMMAND_PORT_OFF)
  21   1          {
  22   2              /** 命令"1"：整板端口全拉低 */
  23   2              Rte_WriteBoardPort(APP_COMMAND_PORT_OFF_LEVEL);
  24   2          }
  25   1          if(command == APP_COMMAND_CHANNEL_OFF)
  26   1          {
  27   2              /** 命令"2"：单个通道拉低 */
  28   2              Rte_WriteBoardChannel(APP_COMMAND_CHANNEL_OFF_LEVEL);
  29   2          }
  30   1          if(command == APP_COMMAND_OUTPUT_RECOVER)
  31   1          {
  32   2              /** 命令"3"：恢复端口为0xFF，通道为1 */
  33   2              Rte_WriteBoardPort(APP_COMMAND_PORT_RECOVER_LEVEL);
  34   2              Rte_WriteBoardChannel(APP_COMMAND_CHANNEL_RECOVER_LEVEL);
  35   2          }
  36   1          if(command == APP_COMMAND_SERIAL_ECHO)
  37   1          {
  38   2              /** 命令"4"：回发收到的字节，清空接收缓存，显示"0" */
  39   2              Rte_SendSerialByte(command);
  40   2              Rte_ClearSerialData();
  41   2              displayValue = APP_COMMAND_DISPLAY_CLEAR_VALUE;  /* 显示 000 */
  42   2          }
  43   1      
  44   1          return displayValue;
  45   1      }


