   1          /**
   2           * @file    Det.c
   3           * @brief   Development Error Tracer implementation
   4           *
   5           * Stores the last-reported error identity and an error counter.
   6           * No runtime action taken — purely for debugger inspection.
   7           */
   8          
   9          #include "Det.h"
  10          
  11          volatile uint16 Det_LastModuleId;
  12          volatile uint8  Det_LastInstanceId;
  13          volatile uint8  Det_LastApiId;
  14          volatile uint8  Det_LastErrorId;
  15          volatile uint16 Det_ErrorCount;
  16          
  17          /**
  18           * 报告错误：记录是谁(moduleId/instanceId)、在哪里(apiId)、出了什么错(errorId)。
  19           * 错误计数+1，便于在调试器中看哪个模块老是报错。
  20           */
  21          /* 轻量错误记录：不打断程序，只保存最后一次错误，方便调试观察。 */
  22          Std_ReturnType Det_ReportError(uint16 moduleId, uint8 instanceId, uint8 apiId, uint8 errorId)
  23          {
  24   1          Det_LastModuleId   = moduleId;    /* 哪个模块 */
  25   1          Det_LastInstanceId = instanceId;  /* 哪个实例 */
  26   1          Det_LastApiId      = apiId;       /* 哪个函数 */
  27   1          Det_LastErrorId    = errorId;     /* 什么错误 */
  28   1          Det_ErrorCount++;                 /* 错误次数+1 */
  29   1      
  30   1          return E_OK;
  31   1      }


