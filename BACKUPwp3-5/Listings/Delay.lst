   1          /**
   2           * @file    Delay.c
   3           * @brief   Software delay implementation — nested busy loops
   4           *
   5           * The inner-loop count of 115 is calibrated for ~1 ms per outer
   6           * iteration at ~11.0592 MHz with default compiler optimisation.
   7           * This is approximate; use a hardware timer for precise timing.
   8           */
   9          
  10          #include "Delay.h"
  11          
  12          /* 阻塞延时：靠空循环消耗时间，简单但CPU会一直等在这里。 */
  13          void Delay_WaitMs(uint16 ms)
  14          {
  15   1          uint i, j;
  16   1          for(i = ms; i > 0; i--)          /* 外层：ms 次 */
  17   1          {
  18   2              for(j = 115; j > 0; j--);    /* 内层：115 次 ≈ 1ms（11.0592MHz） */
  19   2          }
  20   1      }


