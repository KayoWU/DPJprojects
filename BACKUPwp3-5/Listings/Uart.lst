   1          /**
   2           * @file    Uart.c
   3           * @brief   UART MCAL driver implementation
   4           *
   5           * Hardware registers used:
   6           *   SCON — serial control (mode 1: 8-bit UART, variable baud)
   7           *   PCON — SMOD bit controls baud doubling
   8           *   TMOD — timer 1 in 8-bit auto-reload mode
   9           *   TH1/TL1 — timer 1 reload value (sets baud rate)
  10           *   SBUF — serial data buffer (write = TX, read = RX)
  11           *   IE — ES (serial interrupt), EA (global interrupt)
  12           *
  13           * Interrupt: Uart_Isr() (vector 4) handles both RX (RI) and TX (TI).
  14           * Shared data: Uart_RxData is guarded by SchM critical sections.
  15           */
  16          
  17          #include "Uart.h"
  18          #include "Uart_Cfg.h"
  19          #include "SchM.h"
  20          
  21          /**
  22           * UART 接收缓冲区
  23           *
  24           * 被中断（Uart_Isr）写入，被主循环（Uart_GetReceivedData）读取。
  25           * volatile 确保编译器每次都真正读内存而不是寄存器缓存。
  26           * 读写必须用 SchM 临界区保护，防止读到一半被中断打断。
  27           */
  28          static volatile uint8 Uart_RxData;
  29          static volatile boolean Uart_TxBusy = FALSE;
  30          
  31          /**
  32           * 串口硬件初始化
  33           *
  34           * 配置顺序：
  35           *   ① SCON → 模式1（8位UART，允许接收）
  36           *   ② PCON → SMOD=0（波特率不加倍）
  37           *   ③ ES   → 开串口中断
  38           *   ④ TMOD → 定时器1设为8位自动重装模式（产生波特率时钟）
  39           *   ⑤ TH1/TL1 → 根据晶振和波特率计算初值
  40           *   ⑥ TR1  → 启动定时器1
  41           *   ⑦ EA   → 开总中断
  42           */
  43          void Uart_Init(void)
  44          {
  45   1          SCON = 0x50;                                   /* 模式1, REN=1(允许接收) */
  46   1          PCON = PCON & 0x7f;                            /* SMOD=0, 波特率不加倍 */
  47   1          ES   = 1;                                      /* 开串口中断 */
  48   1          TMOD = 0x20;                                   /* T1: 8位自动重装 */
  49   1          TH1  = TL1 = 256 - (UART_FOSC / 12 / 32 / UART_BAUD); /* 波特率 = 晶振/12/32/(256-TH1) */
  50   1          Uart_TxBusy = FALSE;
  51   1          TR1  = 1;                                      /* 启动定时器1 */
C51 COMPILER V9.54   UART                                                                  06/02/2026 01:17:01 PAGE 2   

  52   1          EA   = 1;                                      /* 开总中断 */
  53   1      }
  54          
  55          /**
  56           * 读取串口收到的字节
  57           *
  58           * 整个过程在临界区内完成：关中断 → 读数据 → 恢复中断。
  59           * 防止读到一半时 ISR 又写入了新数据。
  60           */
  61          uint8 Uart_GetReceivedData(void)
  62          {
  63   1          uint8 rxData;
  64   1      
  65   1          SchM_Enter_Uart_RxData();  /* 关中断 */
  66   1          rxData = Uart_RxData;      /* 安全读取 */
  67   1          SchM_Exit_Uart_RxData();   /* 恢复中断 */
  68   1      
  69   1          return rxData;
  70   1      }
  71          
  72          /**
  73           * 清除接收缓存（写0）
  74           */
  75          void Uart_ClearReceivedData(void)
  76          {
  77   1          SchM_Enter_Uart_RxData();
  78   1          Uart_RxData = 0u;
  79   1          SchM_Exit_Uart_RxData();
  80   1      }
  81          
  82          /**
  83           * 发送一个字节
  84           *
  85           * 写 SBUF 即触发发送，发送完成后硬件自动置 TI=1。
  86           * 这里没有等待 TI，是"扔出去就不管"的方式。
  87           */
  88          void Uart_SendByte(uint8 txData)
  89          {
  90   1          if(Uart_TxBusy == FALSE)
  91   1          {
  92   2              Uart_TxBusy = TRUE;
  93   2              SBUF = txData;  /* 写发送缓冲 → 硬件自动开始发送 */
  94   2          }
  95   1      }
  96          
  97          /* 查询串口发送缓冲是否可写。 */
  98          boolean Uart_IsTxReady(void)
  99          {
 100   1          if(Uart_TxBusy == FALSE)
 101   1          {
 102   2              return TRUE;
 103   2          }
 104   1          return FALSE;
 105   1      }
 106          
 107          /**
 108           * 串口中断服务程序（中断向量4）
 109           *
 110           * 两个中断源共用此向量：
 111           *   RI=1 → 收到一个字节：清标志，存到 Uart_RxData
 112           *   TI=1 → 发送完成：    清标志即可
 113           */
C51 COMPILER V9.54   UART                                                                  06/02/2026 01:17:01 PAGE 3   

 114          void Uart_Isr() interrupt 4
 115          {
 116   1          if(RI == 1)
 117   1          {
 118   2              RI = 0;                    /* 清接收中断标志 */
 119   2              Uart_RxData = SBUF;        /* 从硬件缓冲读走数据 */
 120   2          }
 121   1          if(TI == 1)
 122   1          {
 123   2              TI = 0;                    /* 清发送中断标志 */
 124   2              Uart_TxBusy = FALSE;       /* 允许发送下一个字节 */
 125   2          }
 126   1      }


