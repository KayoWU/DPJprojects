  21          /* 初始化RTE背后的全部服务，让App不用关心底层初始化顺序。 */
  22          void Rte_Init(void)
  23          {
  24   1          Serial_Init();   /* 串口初始化 → Uart_Init */
  25   1          Adc_Init();      /* ADC0804风格并口ADC初始化 */
  26   1          IrSensor_Init(); /* 红外接收初始化：INT1 + Timer0 */
  27   1          Led8_Init();     /* 8位LED锁存输出初始化 */
  28   1          Lcd1602_Init();  /* LCD1602初始化 */
  29   1          At24c02_Init();  /* IIC EEPROM初始化 */
  30   1          Timer2_Init();   /* Timer2周期标志初始化 */
  31   1      }
  32          
  33          /* RTE周期调度：推进所有非阻塞状态机。 */
  34          void Rte_MainFunction(void)
  35          {
  36   1          uint16 tick;
  37   1      
  38   1          tick = Timer2_GetTick();
  39   1          Iic_MainFunction();
  40   1          At24c02_MainFunction(tick);
  41   1          Lcd1602_MainFunction(tick);
  42   1          IrSensor_MainFunction();
  43   1      }
  44          
  45          /* 获取1ms系统节拍，给App做周期判断。 */
  46          uint16 Rte_GetSystemTick(void)
  47          {
  48   1          return Timer2_GetTick();
  49   1      }
  50          
