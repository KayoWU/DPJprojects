   1          /**
   2           * @file    Rte.c
   3           * @brief   RTE implementation — thin wrappers over EcuAb services
   4           *
   5           * Each RTE API is a one-liner that delegates to the corresponding
   6           * EcuAb module. This indirection is the key AUTOSAR pattern:
   7           * if the hardware changes, only Rte.c needs updating — App code is
   8           * untouched.
   9           */
  10          
  11          #include "Rte.h"
  12          #include "Serial.h"
