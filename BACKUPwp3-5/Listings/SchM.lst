   1          /**
   2           * @file    SchM.c
   3           * @brief   Schedule Manager implementation — EA save/restore
   4           *
   5           * Saves the global interrupt enable flag (EA) on enter and restores
   6           * it on exit. This allows the critical section to nest correctly even
   7           * if called from code that already has interrupts disabled.
   8           */
   9          
  10          #include "SchM.h"
  11          
  12          /** 保存进入临界区前的EA（中断总开关状态），用于退出时恢复 */
  13          static boolean SchM_UartRxDataSavedEa;
  14          
  15          /* 进入UART接收数据临界区：暂时关总中断，避免读写接收缓存时被打断。 */
  16          void SchM_Enter_Uart_RxData(void)
  17          {
  18   1          SchM_UartRxDataSavedEa = EA;   /* 先存当前中断状态 */
  19   1          EA = 0;                        /* 再关总中断 */
  20   1      }
  21          
  22          /* 退出UART接收数据临界区：恢复进入前的总中断状态。 */
  23          void SchM_Exit_Uart_RxData(void)
  24          {
  25   1          EA = SchM_UartRxDataSavedEa;   /* 恢复之前存的中断状态 */
  26   1      }


