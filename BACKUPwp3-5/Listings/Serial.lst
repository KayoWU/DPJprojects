  22   1      }
  23          
  24          /* 获取收到的串口字节：先检查初始化，再委托给MCAL/Uart。 */
  25          uint8 Serial_GetReceivedData(void)
  26          {
  27   1          if(Serial_IsInitialized == FALSE)
  28   1          {
  29   2              /* 还没初始化就调用 → 记录错误到Det，返回0 */
  30   2              (void)Det_ReportError(SERIAL_MODULE_ID, SERIAL_INSTANCE_ID,
  31   2                                    SERIAL_GET_RECEIVED_DATA_API_ID, SERIAL_E_UNINIT);
  32   2              return 0u;
  33   2          }
  34   1          return Uart_GetReceivedData();    /* 委托给MCAL层读取 */
  35   1      }
  36          
